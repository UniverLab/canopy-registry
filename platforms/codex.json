{
  "name": "codex",
  "config_path": ".codex/config.toml",
  "config_format": "toml",
  "mcp_servers_key": ["mcp_servers"],
  "canopy_entry_key": "canopy",
  "canopy_entry": {
    "url": "http://localhost:7755/mcp"
  },
  "deprecated_keys": [],
  "unsupported_keys": [],
  "recommended_servers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{filesystem_dir}"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": { "MEMORY_FILE_PATH": "{home}/.canopy/memory/memory.jsonl" }
    }
  },
  "cli": {
    "binary": "codex",
    "headless_mode": "exec",
    "interactive_args": "",
    "resume_args": "resume",
    "model_flag": "-m",
    "supports_working_dir": true,
    "working_dir_flag": "-C",
    "env_vars": {},
    "accent_color": [87, 199, 195]
  }
}
