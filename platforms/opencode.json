{
  "name": "opencode",
  "config_path": ".config/opencode/opencode.jsonc",
  "mcp_servers_key": ["mcp"],
  "canopy_entry_key": "canopy",
  "canopy_entry": {
    "type": "remote",
    "url": "http://localhost:7755/mcp",
    "enabled": true
  },
  "deprecated_keys": ["task-trigger"],
  "unsupported_keys": ["autoApprove", "disabled", "tools", "headers"],
  "recommended_servers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{filesystem_dir}"]
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": { "MEMORY_FILE_PATH": "{home}/.canopy/memory/memory.json" }
    }
  },
  "cli": {
    "binary": "opencode",
    "headless_mode": "run",
    "interactive_args": "",
    "model_flag": "-m",
    "supports_working_dir": true,
    "working_dir_flag": "--dir",
    "env_vars": {},
    "accent_color": [92, 156, 245],
    "resume_args": "-c",
    "session_list_cmd": "session list",
    "session_resume_cmd": "--session"
  }
}
