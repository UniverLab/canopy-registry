{
  "name": "copilot",
  "config_path": ".copilot/mcp-config.json",
  "mcp_servers_key": ["mcpServers"],
  "canopy_entry_key": "canopy",
  "canopy_entry": {
    "type": "http",
    "url": "http://localhost:7755/mcp",
    "headers": {},
    "tools": ["*"]
  },
  "deprecated_keys": ["task-trigger"],
  "unsupported_keys": [],
  "recommended_servers": {
    "filesystem": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{filesystem_dir}"],
      "env": {},
      "tools": ["*"]
    },
    "fetch": {
      "type": "local",
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "env": {},
      "tools": ["*"]
    },
    "memory": {
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "{home}/.canopy/memory/memory.jsonl"
      },
      "tools": ["*"]
    }
  },
  "cli": {
    "binary": "copilot",
    "headless_mode": "-p",
    "interactive_args": "",
    "model_flag": "--model",
    "supports_working_dir": false,
    "yolo_flag": "--yolo",
    "env_vars": {},    "accent_color": [170, 0, 170],
    "resume_args": "--continue"
  }
}
