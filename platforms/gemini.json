{
  "name": "gemini",
  "config_path": ".gemini/settings.json",
  "mcp_servers_key": ["mcpServers"],
  "canopy_entry_key": "canopy",
  "canopy_entry": {
    "type": "sse",
    "url": "http://localhost:7755/mcp",
    "headers": {},
    "tools": ["*"]
  },
  "deprecated_keys": [],
  "unsupported_keys": ["autoApprove", "disabled", "tools"],
  "recommended_servers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{filesystem_dir}"]
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": { "MEMORY_FILE_PATH": "{home}/.canopy/memory/memory.json" }
    }
  },
  "cli": {
    "binary": "gemini",
    "headless_mode": "--print",
    "interactive_args": "",
    "model_flag": "--model",
    "supports_working_dir": true,
    "working_dir_flag": "--cwd",
    "env_vars": {},
    "accent_color": [192, 158, 228],
    "resume_args": "--resume"
  }
}
