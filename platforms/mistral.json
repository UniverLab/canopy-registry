{
  "name": "mistral",
  "config_path": ".vibe/config.json",
  "mcp_servers_key": ["mcpServers"],
  "canopy_entry_key": "canopy",
  "canopy_entry": {
    "type": "sse",
    "url": "http://localhost:7755/mcp",
    "headers": {},
    "tools": ["*"]
  },
  "deprecated_keys": [],
  "unsupported_keys": [],
  "recommended_servers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{filesystem_dir}"]
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": { "MEMORY_FILE_PATH": "{home}/.canopy/memory/memory.json" }
    }
  },
  "cli": {
    "binary": "vibe",
    "headless_mode": "-p",
    "interactive_args": "--tui",
    "model_flag": "--agent",
    "supports_working_dir": true,
    "working_dir_flag": "--workdir",
    "env_vars": {},
    "accent_color": [251, 133, 1],
    "resume_args": "-c"
  }
}
