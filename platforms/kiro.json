{
  "name": "kiro",
  "config_path": ".kiro/settings/mcp.json",
  "mcp_servers_key": ["mcpServers"],
  "canopy_entry_key": "canopy",
  "canopy_entry": {
    "url": "http://localhost:7755/mcp",
    "disabled": false,
    "autoApprove": []
  },
  "deprecated_keys": ["task-trigger"],
  "unsupported_keys": [],
  "recommended_servers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{filesystem_dir}"]
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": { "MEMORY_FILE_PATH": "{home}/.canopy/memory/memory.json" }
    }
  },
  "cli": {
    "binary": "kiro-cli",
    "headless_mode": "chat --no-interactive --trust-all-tools",
    "interactive_args": "",
    "model_flag": "--model",
    "supports_working_dir": false,
    "env_vars": {},
    "accent_color": [175, 135, 255],
    "resume_args": "chat --resume-picker"
  }
}
