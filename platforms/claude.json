{
  "name": "claude",
  "config_path": ".claude/settings.json",
  "mcp_servers_key": ["mcpServers"],
  "canopy_entry_key": "canopy",
  "canopy_entry": {
    "type": "remote",
    "url": "http://localhost:7755/mcp",
    "headers": {},
    "tools": ["*"]
  },
  "deprecated_keys": [],
  "unsupported_keys": ["autoApprove", "disabled"],
  "recommended_servers": {
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{filesystem_dir}"]
    },
    "fetch": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "{home}/.canopy/memory/memory.jsonl"
      }
    }
  },
  "cli": {
    "binary": "claude",
    "headless_mode": "-p",
    "interactive_args": "",
    "resume_args": "--resume",
    "model_flag": "--model",
    "supports_working_dir": false,
    "yolo_flag": "--dangerously-skip-permissions",
    "env_vars": {},    "accent_color": [217, 119, 87]
  }
}
