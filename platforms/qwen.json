{
  "name": "qwen",
  "config_path": ".qwen/settings.json",
  "mcp_servers_key": ["mcpServers"],
  "canopy_entry_key": "canopy",
  "canopy_entry": {
    "type": "remote",
    "url": "http://localhost:7755/mcp",
    "headers": {},
    "tools": ["*"]
  },
  "deprecated_keys": [],
  "unsupported_keys": [],
  "recommended_servers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{filesystem_dir}"]
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "{home}/.canopy/memory/memory.jsonl"
      }
    }
  },
  "cli": {
    "binary": "qwen",
    "headless_mode": "--print",
    "interactive_args": "",
    "model_flag": "--model",
    "supports_working_dir": true,
    "working_dir_flag": "--cwd",
    "env_vars": {},
    "accent_color": [206, 168, 244],
    "resume_args": "-c"
  }
}
