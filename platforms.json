{
  "$schema": "https://raw.githubusercontent.com/UniverLab/canopy-registry/main/schema.json",
  "version": 4,
  "platforms": [
    {
      "name": "kiro",
      "config_path": ".kiro/settings/mcp.json",
      "mcp_servers_key": [
        "mcpServers"
      ],
      "canopy_entry_key": "canopy",
      "canopy_entry": {
        "url": "http://localhost:7755/mcp",
        "disabled": false,
        "autoApprove": []
      },
      "deprecated_keys": [
        "task-trigger"
      ],
      "cli": {
        "binary": "kiro-cli",
        "headless_mode": "chat --no-interactive --trust-all-tools",
        "interactive_args": "--tui",
        "model_flag": "--model",
        "supports_working_dir": false,
        "env_vars": {},
        "accent_color": [
          175,
          135,
          255
        ],
        "resume_args": "chat --resume-picker"
      }
    },
    {
      "name": "opencode",
      "config_path": ".config/opencode/opencode.jsonc",
      "mcp_servers_key": [
        "mcp"
      ],
      "canopy_entry_key": "canopy",
      "canopy_entry": {
        "type": "remote",
        "url": "http://localhost:7755/mcp",
        "enabled": true
      },
      "deprecated_keys": [
        "task-trigger"
      ],
      "cli": {
        "binary": "opencode",
        "headless_mode": "run",
        "interactive_args": "",
        "model_flag": "-m",
        "supports_working_dir": true,
        "working_dir_flag": "--dir",
        "env_vars": {},
        "accent_color": [
          92,
          156,
          245
        ],
        "resume_args": "-c"
      }
    },
    {
