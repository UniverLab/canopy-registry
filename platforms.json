{
  "$schema": "https://raw.githubusercontent.com/UniverLab/canopy-registry/main/schema.json",
  "version": 3,
  "platforms": [
    {
      "name": "kiro",
      "config_path": ".kiro/settings/mcp.json",
      "mcp_servers_key": ["mcpServers"],
      "canopy_entry_key": "canopy",
      "canopy_entry": {
        "url": "http://localhost:7755/mcp",
        "disabled": false,
        "autoApprove": []
      },
      "deprecated_keys": ["task-trigger"],
      "cli": {
        "binary": "kiro-cli",
        "headless_mode": "chat --no-interactive --trust-all-tools",
        "model_flag": "--model",
        "supports_working_dir": false,
        "env_vars": {}
      }
    },
    {
      "name": "opencode",
      "config_path": ".config/opencode/opencode.jsonc",
      "mcp_servers_key": ["mcp"],
      "canopy_entry_key": "canopy",
      "canopy_entry": {
        "type": "remote",
        "url": "http://localhost:7755/mcp",
        "enabled": true
      },
      "deprecated_keys": ["task-trigger"],
      "cli": {
        "binary": "opencode",
        "headless_mode": "run",
        "model_flag": "-m",
        "supports_working_dir": true,
        "working_dir_flag": "--dir",
        "env_vars": {}
      }
    },
    {
      "name": "copilot",
      "config_path": ".copilot/mcp-config.json",
      "mcp_servers_key": ["mcpServers"],
      "canopy_entry_key": "canopy",
      "canopy_entry": {
        "type": "http",
        "url": "http://localhost:7755/mcp",
        "headers": {},
        "tools": ["*"]
      },
      "deprecated_keys": ["task-trigger"],
      "cli": {
        "binary": "copilot",
        "headless_mode": "-p",
        "model_flag": "--model",
        "supports_working_dir": false,
        "env_vars": {}
      }
    },
    {
      "name": "qwen",
      "config_path": ".qwen/settings.json",
      "mcp_servers_key": ["mcpServers"],
      "canopy_entry_key": "canopy",
      "canopy_entry": {
        "type": "http",
        "url": "http://localhost:7755/mcp",
        "headers": {},
        "tools": ["*"]
      },
      "deprecated_keys": [],
      "cli": {
        "binary": "qwen",
        "headless_mode": "--print",
        "model_flag": "--model",
        "supports_working_dir": true,
        "working_dir_flag": "--cwd",
        "env_vars": {}
      }
    }
  ]
}
